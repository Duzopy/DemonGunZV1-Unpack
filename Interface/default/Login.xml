<!-- botão entrar -->
	<BMBUTTON item="LoginOK" parent="Login">
		<BOUNDS>
			<X>231</X>
			<Y>578</Y>
			<W>97</W>
			<H>32</H>
		</BOUNDS>
		<STRETCH/>
		<BITMAP type="up">entrar_on.png</BITMAP>
		<BITMAP type="over">entrar_off.png</BITMAP>
		<BITMAP type="down">entrar_on.png</BITMAP>
	</BMBUTTON>		
<!--armação pra abrir com enter o botão enter-->
<BUTTON item="LoginOK" parent="Login">
		<BUTTONLOOK>NormalBmButtonLook</BUTTONLOOK>
		<BOUNDS>
			<X>0</X>
			<Y>0</Y>
			<W>0</W>
			<H>0</H>
		</BOUNDS>
		<DEFAULTKEY>ENTER</DEFAULTKEY>
	</BUTTON>


<BMBUTTON item="Exit" parent="Login">
		<BOUNDS>
			<X>800</X>
			<Y>221</Y>
			<W>31</W>
			<H>31</H>
		</BOUNDS>
		<STRETCH/>
		<BITMAP type="up">sair_off.png</BITMAP>
		<BITMAP type="over">sair_on.png</BITMAP>
		<BITMAP type="down">sair_off.png</BITMAP>
		<CONFIRMMESSAGE>STR:UI_LOGIN_05</CONFIRMMESSAGE> 
		<!-- Do you want to quit the game? -->
		<CONFIRMLOOK>DefaultFrameLook</CONFIRMLOOK>
		<FOCUSABLE>FALSE</FOCUSABLE>
	</BMBUTTON>	
	<!--armação pra fechar ou sair com esc-->
	<BUTTON item="Exit" parent="Login">
	<BUTTONLOOK>NormalBmButtonLook</BUTTONLOOK>
		<BOUNDS>
			<X>0</X>
			<Y>0</Y>
			<W>0</W>
			<H>0</H>
		</BOUNDS>
		<CONFIRMMESSAGE>STR:UI_LOGIN_05</CONFIRMMESSAGE> 
	<DEFAULTKEY>ESC</DEFAULTKEY>
	</BUTTON>
